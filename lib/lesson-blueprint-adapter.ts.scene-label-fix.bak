/**
 * Temporary adapter: converts the Hybrid-C lesson blueprint into a draft shape
 * that the current mock lesson system can consume.
 * Pure logic only; no React, Supabase, or OpenAI.
 */

import type { LessonBlueprint, LessonBlueprintBlock, LessonBlueprintBlockType } from './lesson-blueprint-service'

export type LessonBlueprintDraftItem = {
  prompt: string
  answer: string | null
}

export type LessonBlueprintDraftBlock = {
  type: LessonBlueprintBlockType
  title: string
  description: string
  estimatedMinutes: number
  items: LessonBlueprintDraftItem[]
}

export type LessonBlueprintDraft = {
  theme: string
  blocks: LessonBlueprintDraftBlock[]
}

function normalizeGoal(goal: string): string {
  return goal || 'daily life'
}

function mapSceneKeyToDisplayLabel(
  sceneKey: string,
  uiLanguage: string
): string {
  const labels: Record<string, Record<string, string>> = {
    wake_up: {
      ja: '起床',
      en: 'Wake Up',
      ko: '기상',
      es: 'Despertarse',
    },
    morning_routine: {
      ja: '朝の準備',
      en: 'Morning Routine',
      ko: '아침 준비',
      es: 'Rutina de la mañana',
    },
    going_out: {
      ja: '外出',
      en: 'Going Out',
      ko: '외출',
      es: 'Salir',
    },
    daytime: {
      ja: '日中',
      en: 'Daytime',
      ko: '낮 시간',
      es: 'Durante el día',
    },
    coming_home: {
      ja: '帰宅',
      en: 'Coming Home',
      ko: '귀가',
      es: 'Regresar a casa',
    },
    evening: {
      ja: '夜',
      en: 'Evening',
      ko: '저녁',
      es: 'Noche',
    },
    bedtime: {
      ja: '就寝',
      en: 'Bedtime',
      ko: '취침',
      es: 'Hora de dormir',
    },
  }

  return labels[sceneKey]?.[uiLanguage] ?? labels[sceneKey]?.['en'] ?? sceneKey
}

function createDraftItem(
  prompt: string,
  answer: string | null
): LessonBlueprintDraftItem {
  return { prompt, answer }
}

function buildEnglishPrompt(
  blockType: LessonBlueprintBlockType,
  scene: string
): { prompt: string; answer: string | null } {
  switch (blockType) {
    case 'conversation':
      return {
        prompt: `Listen to the English audio for this scene and understand the meaning.`,
        answer: null,
      }

    case 'typing':
      return {
        prompt: `Type an English phrase that fits this scene.`,
        answer: `I wake up at 7 a.m.`,
      }

    case 'review':
      return {
        prompt: `Review the English expressions for this scene.`,
        answer: null,
      }

    case 'ai_conversation':
      return {
        prompt: `Talk about this scene in English.`,
        answer: null,
      }

    default:
      return {
        prompt: `Practice English for this scene: ${scene}`,
        answer: null,
      }
  }
}

function mapBlockToDraft(block: LessonBlueprintBlock): LessonBlueprintDraftBlock {
  const goal = normalizeGoal(block.goal)
  const sceneKey = goal
  const sceneLabel = mapSceneKeyToDisplayLabel(sceneKey, 'ja')
  const englishContent = buildEnglishPrompt(block.type, sceneKey)

  switch (block.type) {
    case 'conversation':
      return {
        type: 'conversation',
        title: block.title,
        description: sceneLabelJa,
        estimatedMinutes: 5,
        items: [createDraftItem(englishContent.prompt, englishContent.answer)],
      }

    case 'typing':
      return {
        type: 'typing',
        title: block.title,
        description: sceneLabelJa,
        estimatedMinutes: 4,
        items: [createDraftItem(englishContent.prompt, englishContent.answer)],
      }

    case 'review':
      return {
        type: 'review',
        title: block.title,
        description: sceneLabelJa,
        estimatedMinutes: 3,
        items: [createDraftItem(englishContent.prompt, englishContent.answer)],
      }

    case 'ai_conversation':
      return {
        type: 'ai_conversation',
        title: block.title,
        description: sceneLabelJa,
        estimatedMinutes: 6,
        items: [createDraftItem(englishContent.prompt, englishContent.answer)],
      }

    default: {
      const _: never = block.type
      return {
        type: block.type,
        title: block.title,
        description: sceneLabelJa,
        estimatedMinutes: 3,
        items: [createDraftItem(englishContent.prompt, englishContent.answer)],
      }
    }
  }
}

/**
 * Builds a lesson draft from a Hybrid-C blueprint.
 * Preserves block order; one draft block per blueprint block.
 */
export function createLessonBlueprintDraft(
  blueprint: LessonBlueprint
): LessonBlueprintDraft {
  return {
    theme: blueprint.theme,
    blocks: blueprint.blocks.map(mapBlockToDraft),
  }
}
